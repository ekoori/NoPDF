<Project>
  <!-- Version source of truth.
       VersionPrefix (0.0.X) is the public release line â€” bump X for a public
       release via  scripts/release.ps1 -Publish .
       The build number YY is kept in the gitignored  build-number.txt  and is
       auto-incremented on every Debug build (see Directory.Build.targets), so the
       app version is  0.0.X-beta.YY . -->
  <PropertyGroup>
    <VersionPrefix>0.0.5</VersionPrefix>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
  </PropertyGroup>

  <!-- Licensing. noPDF is MIT (see LICENSE). Bundled third-party components and their
       notices are in THIRD-PARTY-NOTICES.md, which ships next to every released binary. -->
  <PropertyGroup>
    <Authors>Igor Krbavcic</Authors>
    <Copyright>Copyright (c) 2026 Igor Krbavcic</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
</Project>
