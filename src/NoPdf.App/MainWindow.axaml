<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:NoPdf.App.ViewModels"
        xmlns:ed="using:NoPdf.App.Editing"
        xmlns:views="using:NoPdf.App.Views"
        xmlns:conv="using:NoPdf.App.Converters"
        xmlns:app="using:NoPdf.App"
        xmlns:sys="using:System"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="NoPdf.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1100" Height="720"
        Icon="/Assets/nopdf.ico"
        Title="noPDF">

    <Window.Resources>
        <conv:EnumEqualsConverter x:Key="EnumEq"/>
        <conv:HexBrushConverter x:Key="HexBrush"/>
        <!-- A tab as a chip (used both top and in the left panel) -->
        <DataTemplate x:Key="TabChip" x:DataType="vm:DocumentViewModel">
            <Button Classes="tabchip" Classes.active="{Binding IsActive}"
                    Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).SelectTabCommand}"
                    CommandParameter="{Binding}"
                    PointerPressed="OnTabPointerPressed">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"
                               MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="&#x25CF;" Foreground="#E08000" FontSize="9" VerticalAlignment="Center"
                               IsVisible="{Binding IsDirty}"/>
                    <Button Classes="tabclose" Content="&#x2715;"
                            Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                            CommandParameter="{Binding}"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.tool">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Keep keyboard focus on the page, never the chrome. -->
        <Style Selector="TabItem"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Button.pageop"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Button.tabclose"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Button.recent"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Border.sidepanel ListBox"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Border.sidepanel TreeView"><Setter Property="IsTabStop" Value="False"/></Style>
        <Style Selector="Button.tool PathIcon">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChromeHover}"/>
        </Style>
        <!-- Active tool: highlighted background + bright icon -->
        <Style Selector="Button.tool.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentActive}"/>
        </Style>
        <Style Selector="Button.tool.active PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
        </Style>
        <!-- Smaller, tighter tabs -->
        <Style Selector="TabItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>
        <!-- Page list: strip selection chrome so pages read as a document -->
        <Style Selector="ListBox.pages > ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBox.pages > ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.pages > ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.tabclose">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.pageop">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.pageop PathIcon">
            <Setter Property="Width" Value="15"/>
            <Setter Property="Height" Value="15"/>
        </Style>
        <Style Selector="Button.recent">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- Tab chips -->
        <Style Selector="Button.tabchip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,3,3"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="Button.tabchip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChromeHover}"/>
        </Style>
        <Style Selector="Button.tabchip.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentActive}"/>
        </Style>
        <!-- Window buttons (minimise/close) -->
        <Style Selector="Button.wbtn">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.wbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChromeHover}"/>
        </Style>
        <Style Selector="Button.wclose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <!-- Dark side panels -->
        <Style Selector="Border.sidepanel TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
        </Style>
        <Style Selector="Border.sidepanel TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
        </Style>
        <Style Selector="Border.sidepanel Button.pageop PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
        </Style>
        <Style Selector="Border.sidepanel Button.pageop:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChromeHover}"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- ===== Top bar: tabs (top mode) + window buttons; drag region ===== -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Background="{DynamicResource ChromeBackground}"
              x:Name="DragStrip" PointerPressed="OnDragStripPressed" DoubleTapped="OnDragStripDoubleTapped">
            <ScrollViewer Grid.Column="0" MaxHeight="{Binding TabsMaxHeight}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          IsVisible="{Binding IsTabsTop}" Padding="4,3">
                <ItemsControl ItemsSource="{Binding Tabs}" ItemTemplate="{StaticResource TabChip}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                        IsVisible="{Binding IsTitlebarHidden}">
                <Button Classes="wbtn" ToolTip.Tip="Minimise" Command="{Binding MinimizeCommand}" Content="&#x2013;"/>
                <Button Classes="wbtn wclose" ToolTip.Tip="Close" Command="{Binding QuitCommand}" Content="&#x2715;"/>
            </StackPanel>
        </Grid>

        <!-- ===== Toolbar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ChromeBackground}" BorderBrush="{DynamicResource ChromeBorder}"
                BorderThickness="0,0,0,1" Padding="8,5"
                IsVisible="{Binding IsToolbarVisible}">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button Classes="tool" ToolTip.Tip="Open (Ctrl+O)" Command="{Binding OpenCommand}">
                    <PathIcon Data="{StaticResource IconOpen}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Save annotations (Ctrl+S)"
                        Command="{Binding SaveCommand}">
                    <PathIcon Data="{StaticResource IconSave}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Print" Command="{Binding PrintCommand}">
                    <PathIcon Data="{StaticResource IconPrint}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Undo (Ctrl+Z)" Command="{Binding UndoCommand}">
                    <PathIcon Data="{StaticResource IconUndo}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Redo (Ctrl+Y)" Command="{Binding RedoCommand}">
                    <PathIcon Data="{StaticResource IconRedo}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Pages panel"
                        Command="{Binding ToggleThumbnailsCommand}"
                        Classes.active="{Binding IsThumbnailsPanelOpen}">
                    <PathIcon Data="{StaticResource IconPages}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Bookmarks panel"
                        Command="{Binding ToggleBookmarksCommand}"
                        Classes.active="{Binding IsBookmarksPanelOpen}">
                    <PathIcon Data="{StaticResource IconBookmark}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Annotation properties"
                        Command="{Binding ToggleAnnotationPanelCommand}"
                        Classes.active="{Binding IsAnnotationPanelOpen}">
                    <PathIcon Data="{StaticResource IconTune}"/></Button>
                <Border Width="1" Background="{DynamicResource Separator}" Margin="5,2"/>

                <Button Classes="tool" ToolTip.Tip="Hand / pan"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Hand}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Hand}}">
                    <PathIcon Data="{StaticResource IconHand}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Select text"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Select}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Select}}">
                    <PathIcon Data="{StaticResource IconSelect}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Zoom tool"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Zoom}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Zoom}}">
                    <PathIcon Data="{StaticResource IconZoom}"/></Button>
                <Border Width="1" Background="{DynamicResource Separator}" Margin="5,2"/>

                <Button Classes="tool" ToolTip.Tip="Highlight"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Highlight}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Highlight}}">
                    <PathIcon Data="{StaticResource IconHighlight}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Sticky note"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Note}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Note}}">
                    <PathIcon Data="{StaticResource IconNote}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Text box"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.TextBox}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.TextBox}}">
                    <PathIcon Data="{StaticResource IconTextBox}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Callout"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Callout}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Callout}}">
                    <PathIcon Data="{StaticResource IconCallout}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Line"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Line}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Line}}">
                    <PathIcon Data="{StaticResource IconLine}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Rectangle"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Rectangle}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Rectangle}}">
                    <PathIcon Data="{StaticResource IconRectangle}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Arrow"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Arrow}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Arrow}}">
                    <PathIcon Data="{StaticResource IconArrow}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Polyline"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Polyline}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Polyline}}">
                    <PathIcon Data="{StaticResource IconPolyline}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Signature"
                        Command="{Binding SelectToolCommand}" CommandParameter="{x:Static ed:EditorTool.Signature}"
                        Classes.active="{Binding SelectedTab.CurrentTool, Converter={StaticResource EnumEq}, ConverterParameter={x:Static ed:EditorTool.Signature}}">
                    <PathIcon Data="{StaticResource IconSignature}"/></Button>
                <Border Width="1" Background="{DynamicResource Separator}" Margin="5,2"/>

                <Button Classes="tool" ToolTip.Tip="Zoom out"
                        Command="{Binding SelectedTab.ZoomOutCommand}">
                    <PathIcon Data="{StaticResource IconZoomOut}"/></Button>
                <TextBlock Text="{Binding SelectedTab.ZoomPercent, StringFormat='{}{0}%'}"
                           Foreground="{DynamicResource ChromeForeground}" VerticalAlignment="Center" MinWidth="42" TextAlignment="Center"/>
                <Button Classes="tool" ToolTip.Tip="Zoom in"
                        Command="{Binding SelectedTab.ZoomInCommand}">
                    <PathIcon Data="{StaticResource IconZoomIn}"/></Button>
                <Button Classes="tool" ToolTip.Tip="Reset zoom"
                        Command="{Binding SelectedTab.ZoomResetCommand}">
                    <PathIcon Data="{StaticResource IconZoomReset}"/></Button>
                <Border Width="1" Background="{DynamicResource Separator}" Margin="5,2"/>

                <Button Classes="tool" ToolTip.Tip="Command line (:)" Click="OnCommandButtonClick">
                    <PathIcon Data="{StaticResource IconCommand}"/></Button>
            </StackPanel>
        </Border>

        <!-- ===== Status bar (very bottom) ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ChromeBackground}" BorderBrush="{DynamicResource ChromeBorder}"
                BorderThickness="0,1,0,0" Padding="10,3">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource StatusForeground}"/>
                <TextBlock Grid.Column="1" Text="{Binding SelectedTab.PageLabel}" FontSize="12"
                           Margin="12,0,0,0" Foreground="{DynamicResource StatusForeground}"
                           IsVisible="{Binding HasDocument}"/>
            </Grid>
        </Border>

        <!-- ===== Command bar (above status bar) ===== -->
        <views:CommandBar DockPanel.Dock="Bottom" DataContext="{Binding CommandBar}"/>

        <!-- ===== Which-key hint (above command bar) ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource ChromeBorder}"
                BorderThickness="0,1,0,0" Padding="10,5"
                IsVisible="{Binding IsWhichKeyVisible}">
            <ItemsControl ItemsSource="{Binding WhichKeyItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                        <Border Background="{DynamicResource WhichKeyChip}" CornerRadius="3" Padding="7,2" Margin="0,0,6,3">
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource ChromeForeground}"
                                       FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ===== Main area ===== -->
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">

            <!-- Left tabs panel -->
            <Border Grid.Column="0" Classes="sidepanel" Width="190" Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource ChromeBorder}" BorderThickness="0,0,1,0"
                    IsVisible="{Binding ShowLeftTabs}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="TABS" FontSize="11" FontWeight="SemiBold"
                               Margin="12,10,12,6"/>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Tabs}" ItemTemplate="{StaticResource TabChip}" Margin="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Bookmarks / outline panel -->
            <Border Grid.Column="1" Classes="sidepanel" Width="260" Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource ChromeBorder}" BorderThickness="0,0,1,0"
                    IsVisible="{Binding IsBookmarksPanelOpen}">
                <DockPanel Margin="0">
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="BOOKMARKS" FontSize="11" FontWeight="SemiBold"
                               Margin="12,10,12,6"/>
                    <ScrollViewer>
                        <StackPanel Margin="4,0,4,8">
                            <TreeView x:Name="OutlineTree"
                                      ItemsSource="{Binding SelectedTab.Outline}"
                                      SelectionChanged="OnOutlineSelected"
                                      Background="Transparent">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:BookmarkNode">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Classes="muted" Text="{Binding PageLabel}"
                                                       FontSize="11" Margin="6,0,0,0"/>
                                        </Grid>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <TextBlock Classes="muted" Text="No bookmarks in this document" FontSize="11"
                                       Margin="10,8" IsVisible="{Binding !SelectedTab.HasOutline}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Panel Grid.Column="2">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                        IsVisible="{Binding !HasDocument}">
                <PathIcon Data="{StaticResource IconOpen}" Width="56" Height="56" Opacity="0.35"/>
                <TextBlock Text="No document open" FontSize="18" HorizontalAlignment="Center"
                           Foreground="{DynamicResource MutedForeground}"/>
                <Button Content="Open a PDF…" Padding="14,6" HorizontalAlignment="Center"
                        Command="{Binding OpenCommand}"/>
                <TextBlock Text="Tip: press : for the command line, / to find"
                           FontSize="12" HorizontalAlignment="Center" Foreground="{DynamicResource MutedForeground}"/>
                <TextBlock Text="{x:Static app:AppVersion.Display}"
                           FontSize="11" HorizontalAlignment="Center" Opacity="0.6"
                           Foreground="{DynamicResource MutedForeground}"/>
                <Border Width="360" Margin="0,8,0,0" IsVisible="{Binding HasRecent}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Recent" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedForeground}" Margin="8,0,0,2"/>
                        <ItemsControl ItemsSource="{Binding RecentFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Button Classes="recent" Content="{Binding}"
                                            Click="OnRecentClick"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ContentControl Content="{Binding SelectedTab}" IsVisible="{Binding HasDocument}">
                <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:DocumentViewModel">
                        <views:DocumentView/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
            </Panel>

            <!-- Thumbnails / pages panel -->
            <Border Grid.Column="3" Classes="sidepanel" Width="196" Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource ChromeBorder}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsThumbnailsPanelOpen}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="PAGES" FontSize="11" FontWeight="SemiBold"
                               Margin="12,10,12,6"/>
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource ChromeBorder}" BorderThickness="0,0,0,1" Padding="6,2">
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <Button Classes="pageop" ToolTip.Tip="Go to the page shown in the view"
                                    Click="OnThumbFocusCurrent">
                                <PathIcon Data="{StaticResource IconTarget}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Rotate left" Click="OnThumbRotateLeft">
                                <PathIcon Data="{StaticResource IconRotateLeft}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Rotate right" Click="OnThumbRotateRight">
                                <PathIcon Data="{StaticResource IconRotateRight}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Move up" Click="OnThumbMoveUp">
                                <PathIcon Data="{StaticResource IconMoveUp}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Move down" Click="OnThumbMoveDown">
                                <PathIcon Data="{StaticResource IconMoveDown}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Insert PDF after" Click="OnThumbInsert">
                                <PathIcon Data="{StaticResource IconInsert}"/></Button>
                            <Button Classes="pageop" ToolTip.Tip="Delete page" Click="OnThumbDelete">
                                <PathIcon Data="{StaticResource IconDelete}"/></Button>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="ThumbList" ItemsSource="{Binding SelectedTab.Thumbnails}"
                             SelectionMode="Multiple"
                             SelectionChanged="OnThumbSelected" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PageThumbnail">
                                <views:ThumbnailView/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Annotation properties panel -->
            <Border Grid.Column="4" Classes="sidepanel" Width="248"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsAnnotationPanelOpen}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="PROPERTIES"
                               FontSize="11" FontWeight="SemiBold" Margin="12,10,12,6"/>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" TextWrapping="Wrap" Margin="12,4"
                               Text="Select an annotation (Select tool) to edit it."
                               IsVisible="{Binding SelectedTab.AnnotationEditor, Converter={x:Static ObjectConverters.IsNull}}"/>
                    <ScrollViewer IsVisible="{Binding SelectedTab.AnnotationEditor, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Margin="12,4,12,12" Spacing="12"
                                    DataContext="{Binding SelectedTab.AnnotationEditor}"
                                    x:DataType="vm:AnnotationEditorViewModel">
                            <TextBlock Text="{Binding TypeName}" FontWeight="SemiBold" FontSize="13"/>

                            <StackPanel Spacing="4" IsVisible="{Binding HasSigner}">
                                <TextBlock Classes="muted" Text="Signer name" FontSize="11"/>
                                <TextBox Text="{Binding SignerName}" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding HasStroke}">
                                <TextBlock Classes="muted" Text="Colour" FontSize="11"/>
                                <TextBox Text="{Binding StrokeHex}" FontSize="12"/>
                                <ItemsControl ItemsSource="{Binding Palette}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="sys:String">
                                            <Button Width="22" Height="22" Margin="0,2,4,0" Padding="0"
                                                    Background="{Binding Converter={StaticResource HexBrush}}"
                                                    Command="{Binding $parent[ItemsControl].((vm:AnnotationEditorViewModel)DataContext).PickStrokeCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="2" IsVisible="{Binding HasWidth}">
                                <TextBlock Classes="muted" Text="Line width" FontSize="11"/>
                                <Slider Minimum="0.5" Maximum="12" Value="{Binding StrokeWidth}"/>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding HasFill}">
                                <CheckBox Content="Fill" IsChecked="{Binding FillEnabled}" FontSize="12"/>
                                <TextBox Text="{Binding FillHex}" IsEnabled="{Binding FillEnabled}" FontSize="12"/>
                                <ItemsControl ItemsSource="{Binding Palette}" IsEnabled="{Binding FillEnabled}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="sys:String">
                                            <Button Width="22" Height="22" Margin="0,2,4,0" Padding="0"
                                                    Background="{Binding Converter={StaticResource HexBrush}}"
                                                    Command="{Binding $parent[ItemsControl].((vm:AnnotationEditorViewModel)DataContext).PickFillCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding HasFrameToggle}">
                                <CheckBox Content="Frame" IsChecked="{Binding FrameEnabled}" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding HasTextColor}">
                                <TextBlock Classes="muted" Text="Text colour" FontSize="11"/>
                                <TextBox Text="{Binding TextHex}" FontSize="12"/>
                                <ItemsControl ItemsSource="{Binding Palette}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="sys:String">
                                            <Button Width="22" Height="22" Margin="0,2,4,0" Padding="0"
                                                    Background="{Binding Converter={StaticResource HexBrush}}"
                                                    Command="{Binding $parent[ItemsControl].((vm:AnnotationEditorViewModel)DataContext).PickTextCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="2" IsVisible="{Binding HasFont}">
                                <TextBlock Classes="muted" Text="Font size" FontSize="11"/>
                                <Slider Minimum="6" Maximum="48" Value="{Binding FontSize}"/>
                            </StackPanel>

                            <StackPanel Spacing="2" IsVisible="{Binding HasOpacity}">
                                <TextBlock Classes="muted" Text="Opacity" FontSize="11"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding Opacity}"/>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding HasContents}">
                                <TextBlock Classes="muted" Text="{Binding ContentsLabel}" FontSize="11"/>
                                <TextBox Text="{Binding Contents}" AcceptsReturn="True"
                                         TextWrapping="Wrap" MinHeight="60" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Signature presets panel -->
            <Border Grid.Column="5" Classes="sidepanel" Width="248"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsSignaturePanelOpen}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="SIGNATURES"
                               FontSize="11" FontWeight="SemiBold" Margin="12,10,12,6"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="12,0,12,6">
                        <Button Content="+ New" FontSize="12" Command="{Binding AddSignaturePresetCommand}"/>
                        <Button Content="Delete" FontSize="12" Command="{Binding DeleteSignaturePresetCommand}"/>
                    </StackPanel>
                    <ListBox DockPanel.Dock="Top" ItemsSource="{Binding SignaturePresets}"
                             SelectedItem="{Binding SelectedSignaturePreset}" Background="Transparent"
                             MaxHeight="150" Margin="8,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SignaturePreset">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                    <TextBlock Text="{Binding Alias, StringFormat=':{0}'}" FontSize="11"
                                               Foreground="{DynamicResource MutedForeground}"/>
                                    <TextBlock Text="🔒" FontSize="11" IsVisible="{Binding UseCertificate}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <ScrollViewer IsVisible="{Binding SelectedSignaturePreset, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Margin="12,8,12,12" Spacing="12"
                                    DataContext="{Binding SelectedSignaturePreset}" x:DataType="vm:SignaturePreset">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="Name" FontSize="11"/>
                                <TextBox Text="{Binding Name}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="Alias (use with :sign &lt;alias&gt;)" FontSize="11"/>
                                <TextBox Text="{Binding Alias}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="Frame colour" FontSize="11"/>
                                <TextBox Text="{Binding FrameColor}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Classes="muted" Text="Frame thickness" FontSize="11"/>
                                <Slider Minimum="0.5" Maximum="8" Value="{Binding FrameThickness}"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Classes="muted" Text="Frame opacity" FontSize="11"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding FrameOpacity}"/>
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <StackPanel Spacing="8">
                                    <CheckBox Content="Use certificate (cryptographic signing)"
                                              FontSize="12" IsChecked="{Binding UseCertificate}"/>
                                    <StackPanel Spacing="8" IsVisible="{Binding UseCertificate}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="muted" Text="Certificate (.pfx)" FontSize="11"/>
                                            <TextBox Text="{Binding CertPath}" FontSize="11" Watermark="path to .pfx"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="muted" Text="Password" FontSize="11"/>
                                            <TextBox Text="{Binding CertPassword}" FontSize="12" PasswordChar="•"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Content="Browse…" FontSize="12"
                                                    Command="{Binding $parent[Window].DataContext.BrowseCertificateCommand}"/>
                                            <Button Content="Generate" FontSize="12"
                                                    Command="{Binding $parent[Window].DataContext.GenerateCertificateCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Classes="muted" TextWrapping="Wrap" FontSize="11"
                                       Text="Select the Signature tool (or :sign alias) and drag on a page. Type the reason into the stamp; a certified signature prompts to save a signed copy when you finish."/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Annotations list panel -->
            <Border Grid.Column="6" Classes="sidepanel" Width="248"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1,0,0,0"
                    IsVisible="{Binding IsAnnotationListPanelOpen}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="muted" Text="ANNOTATIONS"
                               FontSize="11" FontWeight="SemiBold" Margin="12,10,12,6"/>
                    <ListBox ItemsSource="{Binding SelectedTab.AnnotationList}" Background="Transparent"
                             SelectionMode="Single" Margin="4,0,4,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AnnotationListItem">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,1"
                                      Background="Transparent"
                                      PointerPressed="OnAnnotationItemClick">
                                    <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PageLabel}" Classes="muted"
                                               FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
