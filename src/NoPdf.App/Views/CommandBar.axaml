<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoPdf.App.ViewModels"
             xmlns:conv="using:NoPdf.App.Converters"
             x:Class="NoPdf.App.Views.CommandBar"
             x:DataType="vm:CommandBarViewModel"
             IsVisible="{Binding IsVisible}">
    <UserControl.Styles>
        <!-- Strip the Fluent TextBox chrome so it blends into the bar and the
             text is always visible regardless of OS theme. -->
        <Style Selector="TextBox.cmd">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.cmd /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.cmd:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource CommandBackground}" Padding="10,5">
        <StackPanel Spacing="2">
            <!-- Command history (oldest → newest, no scrollbar) -->
            <ItemsControl ItemsSource="{Binding Visible}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CmdHistoryItem">
                        <TextBlock Text="{Binding Text}"
                                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="13"
                                   Foreground="{DynamicResource CommandHistory}"
                                   Opacity="{Binding Current, Converter={x:Static conv:BoolOpacityConverter.Instance}}"
                                   Padding="16,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Input line: prompt + text, vertically centred together -->
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="{Binding Prompt}"
                           Foreground="{DynamicResource CommandPrompt}"
                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="15"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="Input" Classes="cmd"
                         Text="{Binding Text, Mode=TwoWay}"
                         Foreground="{DynamicResource CommandForeground}"
                         CaretBrush="{DynamicResource CommandForeground}"
                         FontFamily="Cascadia Code,Consolas,monospace" FontSize="15"
                         VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
