<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoPdf.App.ViewModels"
             xmlns:views="using:NoPdf.App.Views"
             x:Class="NoPdf.App.Views.DocumentView"
             x:DataType="vm:DocumentViewModel">
    <ListBox Classes="pages" x:Name="PageList"
             ItemsSource="{Binding VisiblePages}"
             Background="{DynamicResource PageAreaBackground}" Padding="{Binding ListPad}"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PageViewModel">
                <views:PageView/>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
